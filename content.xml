<ode><userPreferences><userPreference><key>theme</key><value>base</value></userPreference></userPreferences><odeResources><odeResource><key>odeVersionId</key><value>20260323151711YXBYFU</value></odeResource><odeResource><key>odeId</key><value>20260318162302OOXXAC</value></odeResource><odeResource><key>odeVersionName</key><value>0</value></odeResource><odeResource><key>isDownload</key><value>true</value></odeResource><odeResource><key>eXeVersion</key><value>v3.0.1</value></odeResource></odeResources><odeProperties><odeProperty><key>pp_title</key><value>Impresión 3D</value></odeProperty><odeProperty><key>pp_subtitle</key><value/></odeProperty><odeProperty><key>pp_lang</key><value>es</value></odeProperty><odeProperty><key>pp_author</key><value>José Luis Usero Vílchez</value></odeProperty><odeProperty><key>license</key><value>creative commons: attribution - share alike 4.0</value></odeProperty><odeProperty><key>pp_description</key><value>Impresión 3D</value></odeProperty><odeProperty><key>exportSource</key><value>true</value></odeProperty><odeProperty><key>pp_addExeLink</key><value>true</value></odeProperty><odeProperty><key>pp_addPagination</key><value>false</value></odeProperty><odeProperty><key>pp_addSearchBox</key><value>false</value></odeProperty><odeProperty><key>pp_addAccessibilityToolbar</key><value>false</value></odeProperty><odeProperty><key>pp_extraHeadContent</key><value/></odeProperty><odeProperty><key>footer</key><value/></odeProperty></odeProperties><odeNavStructures><odeNavStructure><odePageId>20260323151712NEEECM</odePageId><odeParentPageId/><pageName>Impresión 3D en el IES Monterroso</pageName><odeNavStructureOrder>1</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titlePage</key><value>Impresión 3D en el IES Monterroso</value></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260323151712NEEECM</odePageId><odeBlockId>20260323151712MJHRFV</odeBlockId><blockName>🧠 Introducción</blockName><iconName>icon_reading</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260323151712NEEECM</odePageId><odeBlockId>20260323151712MJHRFV</odeBlockId><odeIdeviceId>20260318162302DAOKUP</odeIdeviceId><odeIdeviceTypeName>udl-content</odeIdeviceTypeName><htmlView>&lt;div class="exe-udlContent exe-udlContent-engagement"&gt;&lt;section class="exe-udlContent-block"&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;h2&gt;&lt;br&gt;&lt;/h2&gt;
&lt;p&gt;La impresión 3D es una tecnología que nos permite convertir nuestras ideas en objetos reales. En este proyecto aprenderás a seguir todo el proceso: desde diseñar una pieza en el ordenador hasta verla creada por una impresora 3D.&lt;/p&gt;
&lt;p&gt;Trabajaremos en tres pasos:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Diseñar en Tinkercad&lt;/li&gt;
&lt;li&gt;Preparar el archivo con Creality Print&lt;/li&gt;
&lt;li&gt;Imprimir en la impresora 3D&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;A lo largo de esta actividad desarrollarás tu creatividad, pensamiento computacional y habilidades tecnológicas, igual que hacen los ingenieros y diseñadores en la vida real.&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;🎯 Tu objetivo:&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;Diseñar y fabricar tu propia pieza en 3D.&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260318162302DAOKUP","textInfoDurationInput":"","textInfoParticipantsInput":"","textInfoDurationTextInput":"","textInfoParticipantsTextInput":"","textTextarea":"&lt;div class=\"exe-udlContent exe-udlContent-engagement\"&gt;&lt;section class=\"exe-udlContent-block\"&gt;&lt;div class=\"exe-udlContent-content\"&gt;&lt;div class=\"exe-udlContent-content-main\"&gt;&lt;p&gt;\ud83e\udde0 Introducci\u00f3n&lt;br&gt;La impresi\u00f3n 3D es una tecnolog\u00eda que nos permite convertir nuestras ideas en objetos reales. En este proyecto aprender\u00e1s a seguir todo el proceso: desde dise\u00f1ar una pieza en el ordenador hasta verla creada por una impresora 3D.&lt;/p&gt;\n&lt;p&gt;Trabajaremos en tres pasos:&lt;/p&gt;\n&lt;p&gt;Dise\u00f1ar en Tinkercad&lt;br&gt;Preparar el archivo con Creality Print&lt;br&gt;Imprimir en la impresora 3D&lt;br&gt;A lo largo de esta actividad desarrollar\u00e1s tu creatividad, pensamiento computacional y habilidades tecnol\u00f3gicas, igual que hacen los ingenieros y dise\u00f1adores en la vida real.&lt;/p&gt;\n&lt;p&gt;\ud83c\udfaf Tu objetivo: dise\u00f1ar y fabricar tu propia pieza en 3D.&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;","textFeedbackInput":"","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260323151712DKEOSZ</odePageId><odeParentPageId/><pageName>1. Diseñar en TinkerCad</pageName><odeNavStructureOrder>2</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titlePage</key><value>1. Diseñar en TinkerCad</value></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260323151712DKEOSZ</odePageId><odeBlockId>20260323151712OIOLQH</odeBlockId><blockName>DISEÑO 3D CON TINKERCAD</blockName><iconName>edited_ok</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260323151712DKEOSZ</odePageId><odeBlockId>20260323151712OIOLQH</odeBlockId><odeIdeviceId>20260318162302RITJHS</odeIdeviceId><odeIdeviceTypeName>udl-content</odeIdeviceTypeName><htmlView>&lt;div class="exe-udlContent exe-udlContent-expression"&gt;&lt;section class="exe-udlContent-block"&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;h2&gt;🧠 ¿Qué vamos a aprender?&lt;/h2&gt;
&lt;p&gt;En esta actividad aprenderás a diseñar tu primera pieza en 3D usando Tinkercad. Diseñar en 3D es como construir con piezas de LEGO… pero en el ordenador.&lt;/p&gt;
&lt;ul&gt;
&lt;li class="exe-fx exe-accordion"&gt;
&lt;h2&gt;🚀 Paso a paso&lt;/h2&gt;
&lt;ul&gt;
&lt;li id="link_0"&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/tin.jpeg" width="150" height="119" alt="logo" class="position-left"&gt;&lt;strong&gt;Entra en Tinkercad&lt;/strong&gt;&lt;br&gt;Si inicias tu propia cuenta: &lt;a href="https://www.tinkercad.com" target="_blank" rel="noopener"&gt;https://www.tinkercad.com,&amp;nbsp;&lt;/a&gt;&lt;br&gt;En nuestro caso tienes que entrar en una clase &lt;a href="https://www.tinkercad.com/joinclass/Q9Z5LNDSL" id="link_1" target="_blank" title="" rel="noopener"&gt;https://www.tinkercad.com/joinclass/Q9Z5LNDSL&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;La profesora te dará un código para matricularte en la clase.&amp;nbsp;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Crea un diseño nuevo&amp;nbsp;&lt;/strong&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip0.png" width="600" height="1000" alt="pantallazo"&gt;&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;h2&gt;Aprende el entorno&lt;/h2&gt;
&lt;/li&gt;
&lt;li&gt;Elementos &lt;span style="color: #e03e2d;"&gt;importantes&lt;/span&gt;:&lt;br&gt;- 🟦 Plano azul → zona de trabajo&lt;br&gt;- 📦 Formas → a la derecha&lt;br&gt;- 🔍 Zoom → rueda del ratón&lt;br&gt;- 🖱️ Mover → arrastrar con el ratón&lt;/li&gt;
&lt;li&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip1.png"&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;👉 Un llavero con tu nombre&lt;/h2&gt;
&lt;p&gt;Pasos:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Arrastra un cubo&lt;/li&gt;
&lt;li&gt;Cambia el tamaño (por ejemplo: 60 x 20 x 5 mm). &lt;strong&gt;Si te equivocas usa deshacer (antes de seguir cambiando)&lt;/strong&gt;&lt;/li&gt;
&lt;li&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip2.png"&gt;&lt;/li&gt;
&lt;li&gt;Arrastra un texto&lt;/li&gt;
&lt;li&gt;Escribe tu nombre&lt;/li&gt;
&lt;li&gt;Ajusta el tamaño del texto&lt;/li&gt;
&lt;li&gt;Colócalo encima del cubo&lt;br&gt;&lt;/li&gt;
&lt;li&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip3.png"&gt;&lt;/li&gt;
&lt;li&gt;Selecciona todo con el ratón y pulsa agrupar&lt;/li&gt;
&lt;li&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip4.png" width="348" height="147"&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;👉Haz el agujero del llavero&lt;/h2&gt;
&lt;ol&gt;
&lt;li&gt;Arrastra un cilindro&lt;/li&gt;
&lt;li&gt;Cámbialo a modo “agujero”&lt;/li&gt;
&lt;li&gt;Colócalo en un extremo&lt;/li&gt;
&lt;li&gt;Agrupa todo&lt;/li&gt;
&lt;li&gt;Puedes cambiar de perspectiva para asegurarte que está todo correcto&lt;/li&gt;
&lt;li&gt;&lt;img src="{{context_path}}/20260318162302RITJHS/mceclip5.png"&gt;&lt;/li&gt;
&lt;/ol&gt;
&lt;/li&gt;
&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;💡 Consejos del profe&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; Usa medidas realistas (en milímetros)&lt;br&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; No hagas piezas demasiado finas (mínimo 2-3 mm)&lt;br&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; Centra bien las piezas antes de agrupar&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;⚠️ Errores típicos&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Letras flotando (no tocando la base)&lt;br&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Piezas sin agrupar&lt;br&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Diseños demasiado pequeños&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260318162302RITJHS","textInfoDurationInput":"","textInfoParticipantsInput":"","textInfoDurationTextInput":"","textInfoParticipantsTextInput":"","textTextarea":"&lt;div class=\"exe-udlContent exe-udlContent-representation\"&gt;&lt;section class=\"exe-udlContent-block\"&gt;&lt;div class=\"exe-udlContent-content\"&gt;&lt;div class=\"exe-udlContent-content-main\"&gt;&lt;p&gt;\ud83d\udfe2 P\u00c1GINA 1: DISE\u00d1O 3D CON TINKERCAD&lt;br&gt;\ud83e\udde0 \u00bfQu\u00e9 vamos a aprender?&lt;br&gt;En esta actividad aprender\u00e1s a dise\u00f1ar tu primera pieza en 3D usando Tinkercad.&lt;/p&gt;\n&lt;p&gt;Dise\u00f1ar en 3D es como construir con piezas de LEGO\u2026 pero en el ordenador.&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83d\ude80 PASO A PASO&lt;br&gt;1\ufe0f\u20e3 Entra en Tinkercad&lt;br&gt;Ve a: https://www.tinkercad.com&lt;br&gt;Inicia sesi\u00f3n con tu cuenta&lt;br&gt;&lt;br&gt;2\ufe0f\u20e3 Crea un dise\u00f1o nuevo&lt;br&gt;Pulsa \u201cCrear dise\u00f1o\u201d&lt;br&gt;&lt;br&gt;3\ufe0f\u20e3 Aprende el entorno&lt;br&gt;Elementos importantes:&lt;/p&gt;\n&lt;p&gt;\ud83d\udfe6 Plano azul \u2192 zona de trabajo&lt;br&gt;\ud83d\udce6 Formas \u2192 a la derecha&lt;br&gt;\ud83d\udd0d Zoom \u2192 rueda del rat\u00f3n&lt;br&gt;\ud83d\uddb1\ufe0f Mover \u2192 arrastrar con el rat\u00f3n&lt;br&gt;&lt;br&gt;4\ufe0f\u20e3 Crea tu primera figura&lt;br&gt;Vamos a hacer algo sencillo:&lt;/p&gt;\n&lt;p&gt;\ud83d\udc49 Un llavero con tu nombre&lt;/p&gt;\n&lt;p&gt;Pasos:&lt;/p&gt;\n&lt;p&gt;Arrastra un cubo&lt;br&gt;Cambia el tama\u00f1o (por ejemplo: 60 x 20 x 5 mm)&lt;br&gt;Arrastra un texto&lt;br&gt;Escribe tu nombre&lt;br&gt;Ajusta el tama\u00f1o del texto&lt;br&gt;Col\u00f3calo encima del cubo&lt;br&gt;Selecciona todo \u2192 Agrupar&lt;br&gt;&lt;br&gt;5\ufe0f\u20e3 Haz el agujero del llavero&lt;br&gt;Arrastra un cilindro&lt;br&gt;C\u00e1mbialo a modo \u201cagujero\u201d&lt;br&gt;Col\u00f3calo en un extremo&lt;br&gt;Agrupa todo&lt;br&gt;&lt;br&gt;\ud83d\udca1 CONSEJOS DEL PROFE&lt;br&gt;\u2714 Usa medidas realistas (en mil\u00edmetros)&lt;br&gt;\u2714 No hagas piezas demasiado finas (m\u00ednimo 2-3 mm)&lt;br&gt;\u2714 Centra bien las piezas antes de agrupar&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\u26a0\ufe0f ERRORES T\u00cdPICOS&lt;br&gt;\u274c Letras flotando (no tocando la base)&lt;br&gt;\u274c Piezas sin agrupar&lt;br&gt;\u274c Dise\u00f1os demasiado peque\u00f1os&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83c\udfaf MINI RETO&lt;br&gt;Crea uno de estos:&lt;/p&gt;\n&lt;p&gt;Un llavero&lt;br&gt;Un marcador de libros&lt;br&gt;Un soporte simple para el m\u00f3vil&lt;/p&gt;\n&lt;p&gt;Tutoriales en v\u00eddeo de Tinkercad&lt;/p&gt;\n&lt;p&gt;&lt;a href=\"https://www.youtube.com/playlist?list=PLgscO1IbZBSJJiS8y0MEZZRpA4uQzGHbf\"&gt;https://www.youtube.com/playlist?list=PLgscO1IbZBSJJiS8y0MEZZRpA4uQzGHbf&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;","textFeedbackInput":"","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure><odePagStructure><odePageId>20260323151712DKEOSZ</odePageId><odeBlockId>20260323151712FRWIML</odeBlockId><blockName>Mini reto</blockName><iconName>workspace_premiumsvg</iconName><odePagStructureOrder>2</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260323151712DKEOSZ</odePageId><odeBlockId>20260323151712FRWIML</odeBlockId><odeIdeviceId>20260318174014954SL5</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p&gt;Vas a mejorar el llavero:&lt;/p&gt;
&lt;ul style="list-style-type: circle;"&gt;
&lt;li&gt;En lugar de que el nombre esté solo en una cara, el llavero debe tener información diferente por delante y por detrás.&lt;/li&gt;
&lt;li&gt;Asegúrate de que el agujero para el aro esté a una distancia exacta de 4 mm del borde y que el grosor total no supere los 5 mm. Si el borde es muy fino, el llavero se romperá&lt;/li&gt;
&lt;li&gt;Diseña tu llavero en dos partes que encajen perfectamente como un puzzle. Una pieza debe tener un saliente y la otra un hueco con la misma forma.&lt;/li&gt;
&lt;li&gt;Representa la inicial de tu nombre usando solo pequeñas esferas de 2 mm de alto sobre la base del llavero, como si fuera código o lenguaje Braille&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;
            &lt;div class="iDevice_buttons feedback-button js-required"&gt;
                &lt;input type="button" class="feedbacktooglebutton" value="Tutoriales"&gt;
            &lt;/div&gt;
            &lt;div class="feedback js-feedback js-hidden"&gt;&lt;p&gt;&lt;video width="560" height="315" style="display: block; margin-left: auto; margin-right: auto; width: 560px; height: 315px;" controls="controls"&gt;
&lt;source src="https://www.youtube.com/playlist?list=PLgscO1IbZBSJJiS8y0MEZZRpA4uQzGHbf" /&gt;&lt;/video&gt;&lt;/p&gt;
&lt;p&gt;&lt;br /&gt;&lt;/p&gt;&lt;/div&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260318174014954SL5","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;Vas a mejorar el llavero:&lt;/p&gt;\n&lt;ul style=\"list-style-type: circle;\"&gt;\n&lt;li&gt;En lugar de que el nombre esté solo en una cara, el llavero debe tener información diferente por delante y por detrás.&lt;/li&gt;\n&lt;li&gt;Asegúrate de que el agujero para el aro esté a una distancia exacta de 4 mm del borde y que el grosor total no supere los 5 mm. Si el borde es muy fino, el llavero se romperá&lt;/li&gt;\n&lt;li&gt;Diseña tu llavero en dos partes que encajen perfectamente como un puzzle. Una pieza debe tener un saliente y la otra un hueco con la misma forma.&lt;/li&gt;\n&lt;li&gt;Representa la inicial de tu nombre usando solo pequeñas esferas de 2 mm de alto sobre la base del llavero, como si fuera código o lenguaje Braille&lt;/li&gt;\n&lt;/ul&gt;\n&lt;p&gt;&lt;br /&gt;&lt;/p&gt;","textFeedbackInput":"Tutoriales","textFeedbackTextarea":"&lt;p&gt;&lt;video width=\"560\" height=\"315\" style=\"display: block; margin-left: auto; margin-right: auto; width: 560px; height: 315px;\" controls=\"controls\"&gt;\n&lt;source src=\"https://www.youtube.com/playlist?list=PLgscO1IbZBSJJiS8y0MEZZRpA4uQzGHbf\" /&gt;&lt;/video&gt;&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;/p&gt;"}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260323151712TPNEHU</odePageId><odeParentPageId/><pageName>2. Exportar con Creality Print o Cura</pageName><odeNavStructureOrder>3</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titlePage</key><value>2. Exportar con Creality Print o Cura</value></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260323151712TPNEHU</odePageId><odeBlockId>20260323151712IAMIOA</odeBlockId><blockName>EXPORTAR Y PREPARAR CON CREALITY PRINT</blockName><iconName>edited_ok</iconName><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260323151712TPNEHU</odePageId><odeBlockId>20260323151712IAMIOA</odeBlockId><odeIdeviceId>20260318162302FIEOQL</odeIdeviceId><odeIdeviceTypeName>udl-content</odeIdeviceTypeName><htmlView>&lt;div class="exe-udlContent exe-udlContent-expression"&gt;&lt;section class="exe-udlContent-block"&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;h2&gt;🧠 ¿Qué vamos a aprender?&lt;/h2&gt;
&lt;p&gt;Vamos a convertir nuestro diseño en un archivo que la impresora entienda.&lt;/p&gt;
&lt;p&gt;Usaremos Creality Print.&lt;/p&gt;
&lt;div class="exe-fx exe-accordion"&gt;
&lt;h2&gt;1️⃣ Exportar desde Tinkercad&lt;/h2&gt;
&lt;p&gt;Pulsa Exportar&lt;br&gt;Elige formato .STL&lt;br&gt;👉 Este archivo es el modelo 3D&lt;/p&gt;
&lt;h2&gt;2️⃣ Abrir Creality Print&lt;/h2&gt;
&lt;p&gt;Abre el programa&lt;br&gt;Pulsa Importar&lt;br&gt;Selecciona tu archivo STL&lt;/p&gt;
&lt;h2&gt;3️⃣ Colocar la pieza&lt;/h2&gt;
&lt;p&gt;Asegúrate de que está:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;apoyada en la base&lt;/li&gt;
&lt;li&gt;centrada&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;4️⃣ Configuración básica&lt;/h2&gt;
&lt;p&gt;Para empezar usa valores simples:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;Calidad: Normal&lt;/li&gt;
&lt;li&gt;Relleno: 10-15%&lt;/li&gt;
&lt;li&gt;Soportes: solo si hace falta&lt;/li&gt;
&lt;li&gt;Temperatura: automática&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;5️⃣ Generar el archivo&lt;/h2&gt;
&lt;p&gt;Pulsa:&lt;/p&gt;
&lt;p&gt;👉 “Slice” / “Cortar”&lt;/p&gt;
&lt;p&gt;Esto genera un archivo:&lt;/p&gt;
&lt;p&gt;👉 .gcode&lt;/p&gt;
&lt;h2&gt;6️⃣ Guardar en el pen&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;Guarda el archivo en tu USB&lt;br&gt;Ponle un nombre claro:&lt;br&gt;👉 nombre_llavero.gcode&lt;/li&gt;
&lt;/ul&gt;
&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;💡 Consejos del profe&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;✔ Cuanto más grande → más tiempo de impresión&lt;br&gt;✔ Evita piezas muy altas (mejor anchas)&lt;br&gt;✔ Menos relleno = más rápido&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;⚠️ Errores típicos&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;❌ La pieza flotando&lt;br&gt;❌ No hacer “slice”&lt;br&gt;❌ Guardar en formato incorrecto&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260318162302FIEOQL","textInfoDurationInput":"","textInfoParticipantsInput":"","textInfoDurationTextInput":"","textInfoParticipantsTextInput":"","textTextarea":"&lt;div class=\"exe-udlContent exe-udlContent-representation\"&gt;&lt;section class=\"exe-udlContent-block\"&gt;&lt;div class=\"exe-udlContent-content\"&gt;&lt;div class=\"exe-udlContent-content-main\"&gt;&lt;p&gt;\ud83d\udd35 P\u00c1GINA 2: EXPORTAR Y PREPARAR CON CREALITY PRINT&lt;br&gt;\ud83e\udde0 \u00bfQu\u00e9 vamos a aprender?&lt;br&gt;Vamos a convertir nuestro dise\u00f1o en un archivo que la impresora entienda.&lt;/p&gt;\n&lt;p&gt;Usaremos Creality Print.&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83d\udce6 PASO A PASO&lt;br&gt;1\ufe0f\u20e3 Exportar desde Tinkercad&lt;br&gt;Pulsa Exportar&lt;br&gt;Elige formato .STL&lt;br&gt;\ud83d\udc49 Este archivo es el modelo 3D&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;2\ufe0f\u20e3 Abrir Creality Print&lt;br&gt;Abre el programa&lt;br&gt;Pulsa Importar&lt;br&gt;Selecciona tu archivo STL&lt;br&gt;&lt;br&gt;3\ufe0f\u20e3 Colocar la pieza&lt;br&gt;Aseg\u00farate de que est\u00e1:&lt;/p&gt;\n&lt;p&gt;apoyada en la base&lt;br&gt;centrada&lt;br&gt;&lt;br&gt;4\ufe0f\u20e3 Configuraci\u00f3n b\u00e1sica&lt;br&gt;Para empezar usa valores simples:&lt;/p&gt;\n&lt;p&gt;Calidad: Normal&lt;br&gt;Relleno: 10-15%&lt;br&gt;Soportes: solo si hace falta&lt;br&gt;Temperatura: autom\u00e1tica&lt;br&gt;&lt;br&gt;5\ufe0f\u20e3 Generar el archivo&lt;br&gt;Pulsa:&lt;/p&gt;\n&lt;p&gt;\ud83d\udc49 \u201cSlice\u201d / \u201cCortar\u201d&lt;/p&gt;\n&lt;p&gt;Esto genera un archivo:&lt;/p&gt;\n&lt;p&gt;\ud83d\udc49 .gcode&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;6\ufe0f\u20e3 Guardar en el pen&lt;br&gt;Guarda el archivo en tu USB&lt;br&gt;Ponle un nombre claro:&lt;br&gt;\ud83d\udc49 nombre_llavero.gcode&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83d\udca1 CONSEJOS DEL PROFE&lt;br&gt;\u2714 Cuanto m\u00e1s grande \u2192 m\u00e1s tiempo de impresi\u00f3n&lt;br&gt;\u2714 Evita piezas muy altas (mejor anchas)&lt;br&gt;\u2714 Menos relleno = m\u00e1s r\u00e1pido&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\u26a0\ufe0f ERRORES T\u00cdPICOS&lt;br&gt;\u274c La pieza flotando&lt;br&gt;\u274c No hacer \u201cslice\u201d&lt;br&gt;\u274c Guardar en formato incorrecto&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83c\udfaf MINI RETO&lt;br&gt;Antes de exportar, responde:&lt;/p&gt;\n&lt;p&gt;\ud83d\udc49 \u00bfTu pieza es estable?&lt;br&gt;\ud83d\udc49 \u00bfSe imprimir\u00eda sin caerse?&lt;/p&gt;\n&lt;p&gt;V\u00eddeo tutorial&lt;/p&gt;\n&lt;p&gt;&lt;a href=\"https://youtu.be/B7fVVx5jx34\"&gt;https://youtu.be/B7fVVx5jx34&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;","textFeedbackInput":"","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeCompone