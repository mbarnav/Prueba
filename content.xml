odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260323151712UMRFZB</odePageId><odeBlockId>20260323151712PYYXNE</odeBlockId><odeIdeviceId>20260318162302KMYTYC</odeIdeviceId><odeIdeviceTypeName>udl-content</odeIdeviceTypeName><htmlView>&lt;div class="exe-udlContent exe-udlContent-expression"&gt;&lt;section class="exe-udlContent-block"&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;h2&gt;🧠 ¿Qué vamos a aprender?&lt;/h2&gt;
&lt;p&gt;Vamos a imprimir nuestra pieza en una impresora real:&lt;/p&gt;
&lt;p&gt;👉 Creality K1&lt;/p&gt;
&lt;div class="exe-fx exe-accordion"&gt;
&lt;h2&gt;1️⃣ Preparar el USB&lt;/h2&gt;
&lt;p&gt;Introduce el pen en la impresora&lt;/p&gt;
&lt;h2&gt;2️⃣ Encender la impresora&lt;/h2&gt;
&lt;p&gt;Espera a que cargue la pantalla&lt;/p&gt;
&lt;h2&gt;3️⃣ Seleccionar archivo&lt;/h2&gt;
&lt;p&gt;Ve a Print&lt;br&gt;Busca tu archivo .gcode&lt;/p&gt;
&lt;h2&gt;4️⃣ Antes de imprimir&lt;/h2&gt;
&lt;p&gt;Comprueba:&lt;/p&gt;
&lt;p&gt;✔ La base está limpia&lt;br&gt;✔ Hay filamento&lt;br&gt;✔ La impresora está lista&lt;/p&gt;
&lt;h2&gt;5️⃣ Imprimir&lt;/h2&gt;
&lt;p&gt;Pulsa Start&lt;br&gt;La impresora empezará&lt;/p&gt;
&lt;h2&gt;6️⃣ Durante la impresión&lt;/h2&gt;
&lt;p&gt;⚠️ MUY IMPORTANTE:&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;No tocar la impresora&lt;/li&gt;
&lt;li&gt;No mover la pieza&lt;/li&gt;
&lt;li&gt;Avisar si algo va mal&lt;/li&gt;
&lt;/ul&gt;
&lt;h2&gt;7️⃣ Al terminar&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;Espera a que se enfríe&lt;/li&gt;
&lt;li&gt;Retira la pieza con cuidado&lt;/li&gt;
&lt;/ul&gt;
&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;💡 Consejos del profe&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; La primera capa es clave&lt;br&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; Si se despega → parar&lt;br&gt;&lt;span style="color: #169179;"&gt;✔&lt;/span&gt; Paciencia: imprimir lleva tiempo&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;⚠️ Errores típicos&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Tocar la pieza en caliente&lt;br&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Parar la impresora sin avisar&lt;br&gt;&lt;span style="color: #e03e2d;"&gt;❌&lt;/span&gt; Quitar la pieza antes de tiempo&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;section class="exe-udlContent-block js-hidden"&gt;&lt;header class="exe-udlContent-header"&gt;&lt;h2 style="display:none;"&gt;Vídeo tutoriales&lt;/h2&gt;&lt;/header&gt;&lt;div class="exe-udlContent-content"&gt;&lt;div class="exe-udlContent-content-main"&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;p&gt;&lt;iframe width="560" height="314" style="display: block; margin-left: auto; margin-right: auto; width: 560px; height: 314px;" src="https://www.youtube.com/embed/B7fVVx5jx34?list=PLgscO1IbZBSLqhTHJof6YfTBtaDYTU9DS" allowfullscreen="allowfullscreen"&gt;&lt;/iframe&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260318162302KMYTYC","textInfoDurationInput":"","textInfoParticipantsInput":"","textInfoDurationTextInput":"","textInfoParticipantsTextInput":"","textTextarea":"&lt;div class=\"exe-udlContent exe-udlContent-expression\"&gt;&lt;section class=\"exe-udlContent-block\"&gt;&lt;div class=\"exe-udlContent-content\"&gt;&lt;div class=\"exe-udlContent-content-main\"&gt;&lt;p&gt;\ud83d\udd34 P\u00c1GINA 3: IMPRESI\u00d3N CON LA CREALITY K1&lt;br&gt;\ud83e\udde0 \u00bfQu\u00e9 vamos a aprender?&lt;br&gt;Vamos a imprimir nuestra pieza en una impresora real:&lt;/p&gt;\n&lt;p&gt;\ud83d\udc49 Creality K1&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\ud83d\udda8\ufe0f PASO A PASO&lt;br&gt;1\ufe0f\u20e3 Preparar el USB&lt;br&gt;Introduce el pen en la impresora&lt;br&gt;&lt;br&gt;2\ufe0f\u20e3 Encender la impresora&lt;br&gt;Espera a que cargue la pantalla&lt;br&gt;&lt;br&gt;3\ufe0f\u20e3 Seleccionar archivo&lt;br&gt;Ve a Print&lt;br&gt;Busca tu archivo .gcode&lt;br&gt;&lt;br&gt;4\ufe0f\u20e3 Antes de imprimir&lt;br&gt;Comprueba:&lt;/p&gt;\n&lt;p&gt;\u2714 La base est\u00e1 limpia&lt;br&gt;\u2714 Hay filamento&lt;br&gt;\u2714 La impresora est\u00e1 lista&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;5\ufe0f\u20e3 Imprimir&lt;br&gt;Pulsa Start&lt;br&gt;La impresora empezar\u00e1&lt;br&gt;&lt;br&gt;6\ufe0f\u20e3 Durante la impresi\u00f3n&lt;br&gt;\u26a0\ufe0f MUY IMPORTANTE:&lt;/p&gt;\n&lt;p&gt;No tocar la impresora&lt;br&gt;No mover la pieza&lt;br&gt;Avisar si algo va mal&lt;br&gt;&lt;br&gt;7\ufe0f\u20e3 Al terminar&lt;br&gt;Espera a que se enfr\u00ede&lt;br&gt;Retira la pieza con cuidado&lt;br&gt;&lt;br&gt;\ud83d\udca1 CONSEJOS DEL PROFE&lt;br&gt;\u2714 La primera capa es clave&lt;br&gt;\u2714 Si se despega \u2192 parar&lt;br&gt;\u2714 Paciencia: imprimir lleva tiempo&lt;/p&gt;\n&lt;p&gt;&lt;br&gt;\u26a0\ufe0f ERRORES T\u00cdPICOS&lt;br&gt;\u274c Tocar la pieza en caliente&lt;br&gt;\u274c Parar la impresora sin avisar&lt;br&gt;\u274c Quitar la pieza antes de tiempo&lt;/p&gt;\n&lt;p&gt;V\u00eddeo tutoriales&lt;/p&gt;\n&lt;p&gt;&lt;a href=\"https://www.youtube.com/watch?v=B7fVVx5jx34&amp;list=PLgscO1IbZBSLqhTHJof6YfTBtaDYTU9DS\"&gt;https://www.youtube.com/watch?v=B7fVVx5jx34&amp;list=PLgscO1IbZBSLqhTHJof6YfTBtaDYTU9DS&lt;/a&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/section&gt;&lt;/div&gt;","textFeedbackInput":"","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260323151712XYVJYZ</odePageId><odeParentPageId/><pageName>Créditos y licencia</pageName><odeNavStructureOrder>5</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titleNode</key><value/></odeNavStructureProperty><odeNavStructureProperty><key>hidePageTitle</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titleHtml</key><value/></odeNavStructureProperty><odeNavStructureProperty><key>editableInPage</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titlePage</key><value>Créditos y licencia</value></odeNavStructureProperty><odeNavStructureProperty><key>visibility</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>high